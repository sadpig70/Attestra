{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-clearing.schema.json",
  "title": "Clearing packet (structural contract) — verifies a clearing result",
  "type": "object",
  "required": ["packet_id", "clearing"],
  "properties": {
    "packet_id": {"type": "string"},
    "clearing": {"type": "object", "required": ["supply", "allocations"], "properties": {
      "supply": {"type": "number", "minimum": 0},
      "allocations": {"type": "array", "items": {"type": "object", "properties": {
        "party_id": {"type": "string"},
        "amount": {"type": "number"},
        "priority": {"type": "integer"}}}},
      "requests": {"type": "array", "items": {"type": "object", "properties": {
        "party_id": {"type": "string"},
        "amount": {"type": "number"},
        "priority": {"type": "integer"}}}}}}
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-spend.schema.json",
  "title": "Spend-boundary packet (structural contract)",
  "type": "object",
  "required": ["packet_id", "spend"],
  "properties": {
    "packet_id": {"type": "string"},
    "spend": {"type": "object", "properties": {
      "amount": {"type": "number", "minimum": 0},
      "currency": {"type": "string"},
      "recipient": {"type": "string"},
      "current_context": {"type": "string"},
      "spend_context": {"type": "string"},
      "tool_name": {"type": "string"}}},
    "soft_limit": {"type": "number"},
    "blocked_recipients": {"type": "array", "items": {"type": "string"}},
    "restricted_tools": {"type": "array", "items": {"type": "string"}}
  }
}

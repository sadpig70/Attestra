{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-signalmesh.schema.json",
  "title": "SignalMesh exhaust-exchange packet (structural contract)",
  "type": "object",
  "required": ["packet_id", "policy", "streams"],
  "properties": {
    "packet_id": {"type": "string"},
    "subject": {"type": "string"},
    "policy": {"type": "object", "properties": {
      "block_pii": {"type": "boolean"},
      "require_consent_for_restricted": {"type": "boolean"},
      "min_quality": {"type": "number"}}},
    "streams": {"type": "array", "minItems": 1, "items": {"type": "object",
      "required": ["stream_id", "exhaust_type", "volume", "sensitivity"], "properties": {
        "stream_id": {"type": "string"},
        "exhaust_type": {"type": "string", "enum": [
          "logs", "disputes", "failed_migrations", "compliance_traces",
          "residual_heat", "latency_traces", "error_traces"]},
        "volume": {"type": "number", "minimum": 0},
        "sensitivity": {"type": "string", "enum": ["public", "internal", "restricted", "pii"]},
        "consent_obtained": {"type": "boolean"},
        "quality": {"type": "number", "minimum": 0}}}}
  }
}

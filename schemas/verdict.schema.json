{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/verdict.schema.json",
  "title": "Attestra CheckResult / run_gates result",
  "type": "object",
  "properties": {
    "subject": {"type": "string"},
    "verdict": {"type": "string", "enum": ["valid", "thin", "breach"]},
    "reason": {"type": "string"},
    "worst": {"type": ["string", "null"]},
    "packet_ok": {"type": "boolean"},
    "evaluated_at": {"type": "string"},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gate": {"type": "string"},
          "verdict": {"type": "string", "enum": ["valid", "thin", "breach"]},
          "reason": {"type": "string"},
          "evidence_path": {"type": "string"},
          "evidence_ok": {"type": "boolean"}
        },
        "required": ["gate", "verdict", "reason"]
      }
    }
  },
  "required": ["verdict", "checks"]
}

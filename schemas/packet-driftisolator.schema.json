{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-driftisolator.schema.json",
  "title": "DriftIsolator packet (structural contract)",
  "type": "object",
  "required": ["packet_id", "drift"],
  "properties": {
    "packet_id": {"type": "string"},
    "subject": {"type": "string"},
    "drift": {"type": "object", "required": ["decision"], "properties": {
      "decision": {"type": "string"},
      "minimal_event_count": {"type": "number"},
      "one_minimal": {"type": "boolean"},
      "original_event_count": {"type": "number"},
      "receipt_sha256": {"type": "string"},
      "source_project": {"type": "string"},
      "source_result": {"type": "string"},
      "handback_trace_sha256": {"type": "string"}}}
  }
}

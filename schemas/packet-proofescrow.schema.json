{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-proofescrow.schema.json",
  "title": "ProofEscrow packet (structural contract)",
  "type": "object",
  "required": ["packet_id", "escrow"],
  "properties": {
    "packet_id": {"type": "string"},
    "subject": {"type": "string"},
    "escrow": {"type": "object", "required": ["decision"], "properties": {
      "decision": {"type": "string"},
      "reasons": {"type": "array", "items": {"type": "object", "properties": {
        "code": {"type": "string"},
        "path": {"type": "string"}}}},
      "receipt_sha256": {"type": "string"},
      "source_project": {"type": "string"},
      "source_result": {"type": "string"},
      "handback_trace_sha256": {"type": "string"}}}
  }
}

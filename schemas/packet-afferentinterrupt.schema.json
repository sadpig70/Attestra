{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-afferentinterrupt.schema.json",
  "title": "AfferentInterrupt agent-trace packet (structural contract)",
  "type": "object",
  "required": ["packet_id", "trace"],
  "properties": {
    "packet_id": {"type": "string"},
    "subject": {"type": "string"},
    "safety_policies": {"type": "array", "items": {"type": "string"}},
    "trace": {"type": "array", "items": {"type": "object", "required": ["step", "state", "action"], "properties": {
      "step": {"type": "number"},
      "state": {"type": "string"},
      "action": {"type": "string"},
      "resource_cost": {"type": "number", "minimum": 0},
      "safety_checked": {"type": "boolean"}}}}
  }
}

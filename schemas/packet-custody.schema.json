{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "attestra/packet-custody.schema.json",
  "title": "Custody-relay packet (structural contract)",
  "type": "object",
  "required": ["packet_id", "relay"],
  "properties": {
    "packet_id": {"type": "string"},
    "relay": {"type": "object", "properties": {
      "chain": {"type": "array"},
      "chain_continuous": {"type": "boolean"},
      "send_hash": {"type": "string"},
      "recv_hash": {"type": "string"},
      "relay_route": {"type": "string"},
      "allowed_routes": {"type": "array", "items": {"type": "string"}}}}
  }
}
